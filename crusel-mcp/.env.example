# Pick the network: testnet (mock feeds, demo) or mainnet (real X Layer feeds).
# Defaults to testnet. This selects the RPC and token set automatically.
NETWORK=testnet

# Contract addresses. On testnet these default to the deployed demo.
# On mainnet, set them after running script/DeployMainnet.s.sol.
BRAIN=0x1D8B77A44Edac389721dE0769f8f55A565cF0526
RECORD=0xF1766Fa22F203AE07CaFE643CA9e742ffBc9AC8b

# Optional: override the RPC (otherwise derived from NETWORK).
# XLAYER_RPC=https://rpc.xlayer.tech

PORT=3001
